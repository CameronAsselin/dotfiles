{
   "layer": "top",
   "position": "top",
   "height": 30,
   "margin": "0 0 0 0",

   "modules-left": ["custom/menu", "custom/crypto", "custom/gold", "custom/silver"],
   "modules-center": ["hyprland/workspaces", "sway/workspaces"],
    "modules-right": ["cpu", "memory", "network", "battery", "pulseaudio", "temperature", "custom/usb", "custom/vpn", "bluetooth", "tray", "custom/weather", "clock", "custom/power"],    
// Modules configuration
 
   "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
         "urgent": "пБ™",
         "active": "у∞ЪМ"
      },
      "persistent-workspaces": {
         "1": [],
         "2": []
      }
   },
   "sway/workspaces": {
      "format": "{icon}",
      "format-icons": {
         "urgent": "пБ™",
         "active": "у∞ЪМ"
      },
      "persistent-workspaces": {
         "1": [],
         "2": []
      }
   },
   "mpris": {
      "format": "{player_icon}{artist} - {title}",
      "artist-len": 18,
      "title-len": 49,
      "interval": 2,
      "player-icons": { 
         "default": "рЯОµ ",
         "mpv": "пАИ  ",
         "strawberry": "рЯНУ ",
         "firefox": "пЙ©  ",
         "spotify": "пЖЉ "
      }
   },
   "custom/weather": {
      "exec": "~/.config/waybar/scripts/get_weather.sh",
      "return-type": "json",
      "format": "{}",
      "tooltip": true,
      "interval": 3600,
      "on-click": "firefox https://wttr.in/"
   },
   "custom/menu": {
      "format": "пЕЉ ",
      "on-click": "rofi -show drun",
      "on-click-right": "rofi -show run",
      "tooltip": false
   },
   "custom/vpn": {
      "format": "пВД ",
      "exec": "echo '{\"class\": \"connected\"}'",
      "exec-if": "test -d /proc/sys/net/ipv4/conf/tun0",
      "return-type": "json",
      "interval": 5,
      "on-click-right": "nm-connection-editor",
      "tooltip": true
   },
   "custom/usb": {
      "format": "у±З∞",
      "exec": "echo '{\"class\": \"connected\"}'",
      "exec-if": "test -d /sys/bus/usb/devices/2-1 || test -d /sys/bus/usb/devices/2-2",
      "return-type": "json",
      "interval": 5,
      "on-click": "thunar",
      "tooltip": true
   },
   "cpu": {
      "interval": "2",
      "format": "пТЉ {usage}%",
      "on-click": "gnome-system-monitor"
   },
   "memory": {
      "interval": "5",
      "format": "оњЕ {used:0.1f}GB/{total:0.1f}GB",
      "tooltip-format": "RAM:\n{used:0.1f}GB/{total:0.1f}GB",
      "on-click": "gnome-system-monitor"
   },
   "temperature": {
      "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
      "critical-threshold": 80,
      "format": "",
      "format-critical": "пЛЗ!",
      "format-icons": ["пЛЛ","пЛК","пЛЙ","пЛИ","пЛЗ"],
      "tooltip-format": "CPU:\n{temperatureF}¬∞F\n{temperatureC}¬∞C",
      "on-click": "gnome-system-monitor"
   },
   "backlight": {
      "format": "{icon} {percent: >3}%",
      "format-icons": ["пЖЕ"],
      "on-scroll-down": "brightnessctl -c backlight set 10%-",
      "on-scroll-up": "brightnessctl -c backlight set +10%"
   },
   "battery": {    
      "format": "{icon}",
      "format-icons": ["у∞ЫЮ ођЕ ођЕ ођЕ ођЕ ","пАД ођЕ ођЕ ођЕ ођЕ ","пАД у∞ЫЮ ођЕ ођЕ ођЕ ","пАД пАД ођЕ ођЕ ођЕ ","пАД пАД у∞ЫЮ ођЕ ођЕ ","пАД пАД пАД ођЕ ођЕ ","пАД пАД пАД у∞ЫЮ ођЕ ","пАД пАД пАД пАД ођЕ ","пАД пАД пАД пАД у∞ЫЮ ","пАД пАД пАД пАД пАД "],
      "interval": 5,
      "tooltip-format": "Capacity: {capacity}%\n{timeTo}",
      "states": {
         "full": 100,
         "great": 98,
         "good": 80,
         "fair": 50,
         "warning": 30,
         "critical": 10
      }
   },
   "network": {
      //"interface": "wlan0", // (Optional) To force the use of this interface
      "interval": "2",        
      "format": "пБ£ {bandwidthDownBits} пБҐ {bandwidthUpBits}",
      "format-disconnected": "у∞±Ѓ",
      "on-click": "gnome-system-monitor",
      "tooltip-format": "{essid} ({ifname}): {ipaddr}\nUp: {bandwidthUpBytes}\nDown: {bandwidthDownBytes}",
      "tooltip-format-disconnected": "disconnected"
   },
   "pulseaudio": {
      "scroll-step": 1,
      "format": "{icon}",
      "format-muted": "у∞ЭЯ",
      "format-icons": {
         "headphones": "у∞ЛЛ",
         "handsfree": "у±†∞",
         "headset": "у∞ЛО",
         "phone": "пВХ",
         "portable": "у∞ДЬ",
         "car": "пЖє",
         "default": ["у∞Хњ", "у∞ЦА", "у∞ХЊ"]
      },
      "on-click": "pavucontrol",
      "on-scroll-up": "pamixer -ui 2 && pamixer --get-volume > $SWAYSOCK.wob",
      "on-scroll-down": "pamixer -ud 2 && pamixer --get-volume > $SWAYSOCK.wob",
      "tooltip-format": "Volume: {volume: >3}%\n{desc}"
   },
   "custom/crypto": {
      "format": "оіК{}",
      "exec": "~/.config/waybar/scripts/crypto/crypto.py",
      "on-click": "firefox https://www.coingecko.com/en/coins/monero"
   },
   "custom/silver": {
      "format": "оЈ® {}",
      "exec": "python ~/.config/waybar/scripts/ticker.py SI=F",
      "on-click": "firefox https://finance.yahoo.com/quote/SI=F/",
      "restart-interval": 10
   },
   "custom/gold": {
      "format": "оЈ® {}",
      "exec": "python ~/.config/waybar/scripts/ticker.py GC=F",
      "on-click": "firefox https://finance.yahoo.com/quote/GC=F/",
      "restart-interval": 10
   },
   "bluetooth": {
      "format": "пКФ",
      "format-on": "пКФ",
      "format-disabled": "у∞В≤",
      "format-off": "у∞В≤",
      "format-connected": "пКФ",
      "tooltip-format": "{controller_alias}\t{controller_address}",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-disabled": "disabled",
      "tooltip-format-off": "off",
      "on-click": "blueberry"
   },
   "tray": {
      "spacing": 10,
      "icon-size": 20,
      "show-passive-items": "true",
      "reverse-direction": "false"
   },
   "clock": {
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "format": "{:%a %b %d\n %I:%M %p}",
      "interval": 1,
      "on-click": "thunderbird -calendar",
      "calendar": {
         "mode": "month",
         "mode-mon-col": 3,
         "on-scroll": 1,
         "on-click-right": "mode",
         "format": {
            "months":     "<span color='#F4B8E4'><b>{}</b></span>",
            "days":       "<span color='#A6D189'><b>{}</b></span>",
            "weeks":      "<span color='#E5C890'><b>W{}</b></span>",
            "weekdays":   "<span color='#F5A97F'><b>{}</b></span>",
            "today":      "<span color='#E78284'><b><u>{}</u></b></span>"
         }
      }
   },
   "custom/power": {
	"format": "вПї",
        "on-click": "~/.config/waybar/scripts/shutdown.sh",
	"tooltip-format": "Power options"
   }
}
